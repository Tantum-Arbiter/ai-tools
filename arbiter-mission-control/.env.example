# ── ARBITER Mission Control ──────────────────────────────────────
# Copy this to .env and fill in your values

# LLM Provider — "claude" (fast + cheap), "ollama" (free local), "openai" (legacy)
LLM_PROVIDER=claude

# Claude API (Haiku 3.5 — cheapest model, ~$3/month typical use)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Cost safeguards (defaults are conservative)
# CLAUDE_DAILY_BUDGET_USD=1.0    # Hard cap — falls back to Ollama when hit
# CLAUDE_RPM_LIMIT=30            # Max requests per minute
# CLAUDE_SESSION_LIMIT=500       # Max requests per server session

# Ollama (free local fallback — install from https://ollama.com, then: ollama pull phi4)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4

# OpenRouter (CEO agents + panel generation — $0.15/M in, $0.60/M out)
# Get key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Cost safeguards (defaults are conservative — ~$3/month)
# OPENROUTER_DAILY_BUDGET_USD=0.10   # Hard cap per day ($0.10 × 30 = $3/mo)
# OPENROUTER_RPM_LIMIT=30            # Max requests per minute
# OPENROUTER_SESSION_LIMIT=500       # Max requests per server session
# OPENROUTER_TIMEOUT=60              # Seconds per request (prevents hanging)
# OPENROUTER_AGENT_MODEL=openai/gpt-4o-mini   # Model for CEO agents
# OPENROUTER_PANEL_MODEL=openai/gpt-4o-mini   # Model for dashboard panels

# OpenAI (legacy fallback — not needed if using OpenRouter)
OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# Google Gemini (free tier — CEO Researcher & Analyst agents)
GOOGLE_API_KEY=your-google-api-key-here

# ComfyUI
COMFYUI_BASE_URL=http://localhost:8188

# Email Intelligence (Gmail with App Password)
# 1. Go to myaccount.google.com → Security → 2-Step Verification → App passwords
# 2. Generate an app password for "Mail"
EMAIL_ADDRESS=your.email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# GCP Platform Monitoring
# Run: gcloud auth application-default login (one-time)
# Or set GCP_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west2
# GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX  (optional, for billing data)

# RevenueCat
# app.revenuecat.com → Project Settings → API Keys → Secret key
REVENUECAT_API_KEY=sk_your-secret-key
REVENUECAT_PROJECT_ID=your-project-id
