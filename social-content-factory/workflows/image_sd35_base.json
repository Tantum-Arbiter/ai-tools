{
  "_workflow": "social-content-factory base image render (SD 3.5 Medium)",
  "_placeholders": ["{{MODEL}}", "{{POSITIVE}}", "{{NEGATIVE}}", "{{SEED}}", "{{STEPS}}", "{{CFG}}", "{{WIDTH}}", "{{HEIGHT}}", "{{FILENAME_PREFIX}}"],
  "1": {
    "inputs": {
      "seed": "{{SEED}}",
      "steps": "{{STEPS}}",
      "cfg": "{{CFG}}",
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 1,
      "model": ["3", 0],
      "positive": ["5", 0],
      "negative": ["6", 0],
      "latent_image": ["7", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"}
  },
  "3": {
    "inputs": {"ckpt_name": "{{MODEL}}"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Checkpoint"}
  },
  "4": {
    "inputs": {"samples": ["1", 0], "vae": ["3", 2]},
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "5": {
    "inputs": {
      "text": "{{POSITIVE}}",
      "clip": ["3", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "6": {
    "inputs": {
      "text": "{{NEGATIVE}}",
      "clip": ["3", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"}
  },
  "7": {
    "inputs": {
      "width": "{{WIDTH}}",
      "height": "{{HEIGHT}}",
      "batch_size": 1
    },
    "class_type": "EmptySD3LatentImage",
    "_meta": {"title": "Canvas Size"}
  },
  "8": {
    "inputs": {"filename_prefix": "{{FILENAME_PREFIX}}", "images": ["4", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
}
