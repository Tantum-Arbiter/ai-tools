# ============================================================
# Grow with Freya — Engagement Hub
# Copy to .env — NEVER commit .env to git
# ============================================================

# ---- LLM -----------------------------------------------------
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o

# ---- Instagram Graph API -------------------------------------
META_ACCESS_TOKEN=your_long_lived_token
META_INSTAGRAM_ACCOUNT_ID=your_ig_professional_account_id
META_APP_SECRET=your_app_secret          # for webhook signature verification

# ---- Facebook Page -------------------------------------------
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token   # different from user token

# ---- Webhook Server ------------------------------------------
# Deploy webhook.py to Railway/Render/Fly.io (free tier)
WEBHOOK_VERIFY_TOKEN=growwithfreya_webhook_token   # set same in Meta Developer Console

# ---- Storage -------------------------------------------------
ENGAGEMENT_DB_PATH=data/engagement.db
