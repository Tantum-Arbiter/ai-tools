# ============================================================
# Grow with Freya - Content Automation Pipeline
# Copy to .env — NEVER commit .env to git
# ============================================================

# ---- LLM (choose one) ----------------------------------------
# Option A: Claude (best quality, Claude Code Pro = free for you)
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-opus-4-5

# Option B: OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Option C: Local Ollama (100% free, no internet needed)
USE_LOCAL_LLM=false
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2

# ---- YouTube Data API v3 -------------------------------------
# Free: 10,000 quota units/day
# Get: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=your_key_here
YOUTUBE_REGION_CODE=GB

# YouTube OAuth (for uploading - different from API key)
# Get: Google Cloud Console → OAuth 2.0 → Desktop App
# Run scripts/auth/youtube_auth.py once to generate refresh token
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ---- Instagram Graph API -------------------------------------
# Get: https://developers.facebook.com → Create App → Instagram Graph API
META_ACCESS_TOKEN=your_long_lived_token
META_INSTAGRAM_ACCOUNT_ID=your_ig_account_id

# ---- ComfyUI (local Windows PC) ------------------------------
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_OUTPUT_DIR=C:/ComfyUI/output

# ---- Brand ---------------------------------------------------
BRAND_NAME=Grow with Freya
BRANDED_HASHTAG=#growwithfreya
BRAND_NICHE=parenting,early years,toddlers,emotional literacy,calm parenting

# ---- Storage -------------------------------------------------
DB_PATH=data/state.db
CONTENT_OUTPUT_DIR=data/content
REPORTS_DIR=reports
