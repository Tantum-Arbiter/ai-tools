# ── LLM ──────────────────────────────────────────────────────────────
# Local Ollama model for query parsing (default: phi4:14b)
WORK_AI_LLM_MODEL=phi4:14b
WORK_AI_LLM_BASE_URL=http://localhost:11434

# ── GitHub ───────────────────────────────────────────────────────────
DAYJOB_GITHUB_ORG=
DAYJOB_GITHUB_PROJECT_NUMBER=0
DAYJOB_GITHUB_REPOS=
DAYJOB_GITHUB_PAT_SEARCH=
DAYJOB_BROWSER_PROFILE_PATH=

# ── Monday.com (READ ONLY) ──────────────────────────────────────────
MONDAY_API_TOKEN=
MONDAY_BOARD_IDS=

# ── Safety ───────────────────────────────────────────────────────────
# 64+ hex chars for HMAC signing of confirmation tokens
DAYJOB_HMAC_SECRET=

# ── Server ───────────────────────────────────────────────────────────
WORK_AI_PORT=8100
